# Ottie Desktop 环境配置
# 复制此文件为 .env 并填入真实值

# Matrix 服务器（必填）
VITE_MATRIX_URL=http://localhost:8008
VITE_REG_TOKEN=ottie-dev-token

# LLM 配置（可选，不填则用规则引擎）
# 支持：OpenAI 直连、AIHubMix 中转、Ollama 本地、任何 OpenAI 兼容端点
VITE_LLM_BASE_URL=https://aihubmix.com/v1
VITE_LLM_API_KEY=your-api-key-here
VITE_LLM_MODEL=claude-sonnet-4-20250514

# 示例：Ollama 本地模型
# VITE_LLM_BASE_URL=http://localhost:11434/v1
# VITE_LLM_API_KEY=ollama
# VITE_LLM_MODEL=gemma2:9b
