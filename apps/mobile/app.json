{
  "expo": {
    "name": "Ottie",
    "slug": "ottie",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "ottie",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#f0f2f5"
    },
    "ios": {
      "bundleIdentifier": "com.ottie.app",
      "supportsTablet": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.ottie.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#25D366"
      }
    },
    "platforms": [
      "ios",
      "android"
    ],
    "plugins": [
      "expo-font",
      "expo-router",
      "expo-asset"
    ],
    "extra": {
      "eas": {
        "projectId": "888b1e3a-48b6-4cc8-83bd-4ec37629fb9a"
      }
    },
    "owner": "gdbzriww"
  }
}
